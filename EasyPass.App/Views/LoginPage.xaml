<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="EasyPass.App.Views.LoginPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             Title="Login">

    <VerticalStackLayout Padding="30" Spacing="20">

        <Label Text="Welcome to EasyPass"
               FontSize="24"
               HorizontalOptions="Center" />

        <!-- Two-way binding: Entry text updates ViewModel.Email and vice versa -->
        <Entry Text="{Binding Email}"
               Placeholder="Username"
               Keyboard="Default" />

        <Entry Text="{Binding Pin}"
               Placeholder="PIN"
               IsPassword="True"
               Keyboard="Numeric" />

        <!-- IsVisible bound to HasError (bool property on ViewModel) -->
        <Label Text="{Binding ErrorMessage}"
               TextColor="Red"
               IsVisible="{Binding HasError}"
               FontSize="14"
               HorizontalOptions="Center" />

        <!-- IsVisible and IsRunning both bound to IsLoading -->
        <ActivityIndicator IsRunning="{Binding IsLoading}"
                          IsVisible="{Binding IsLoading}"
                          Color="#4B24D4"
                          HeightRequest="40" />

        <!-- Command binding: LoginCommand is generated by [RelayCommand] on LoginAsync() -->
        <Button Text="Login"
                Command="{Binding LoginCommand}"
                BackgroundColor="#4B24D4"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="50" />

        <!-- IsVisible bound to IsBiometricVisible -->
        <Button Text="Login with Biometrics"
                Command="{Binding LoginWithBiometricCommand}"
                IsVisible="{Binding IsBiometricVisible}"
                BackgroundColor="#4B24D4"
                TextColor="White"
                CornerRadius="10"
                HeightRequest="50" />

        <Button Text="Register"
                Clicked="OnRegisterClicked"
                BackgroundColor="#4DA6FF"
                TextColor="White"
                FontSize="16"
                CornerRadius="10"
                HeightRequest="45"
                Margin="0,10,0,0"
                FontAttributes="Bold"/>

    </VerticalStackLayout>
</ContentPage>
