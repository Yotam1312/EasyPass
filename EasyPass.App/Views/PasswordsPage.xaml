<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="EasyPass.App.Views.PasswordsPage"
             Title="My Passwords">

    <ContentPage.Resources>
        <ResourceDictionary Source="/Resources/Styles/AppStyles.xaml" />
    </ContentPage.Resources>

    <Grid RowDefinitions="Auto,*"
          Padding="{StaticResource SpacingMedium}">

        <!-- Header and Actions Section -->
        <StackLayout Grid.Row="0" Spacing="{StaticResource SpacingMedium}">
            <Grid ColumnDefinitions="*,Auto">
                <Label Grid.Column="0"
                       Text="Password Manager"
                       Style="{StaticResource HeaderLabel}"
                       HorizontalOptions="Center"
                       VerticalOptions="Center" />

                <!-- Logout button bound to LogoutCommand on PasswordsViewModel -->
                <Button Grid.Column="1"
                        Text="Logout"
                        Command="{Binding LogoutCommand}"
                        BackgroundColor="#FF4444"
                        TextColor="White"
                        CornerRadius="8"
                        HeightRequest="40"
                        SemanticProperties.Hint="Logout from the app" />
            </Grid>

            <Frame Style="{StaticResource PasswordCard}"
                   Padding="12">
                <Grid ColumnDefinitions="*,Auto,Auto">
                    <!-- SearchText two-way bound — OnSearchTextChanged in ViewModel filters the list -->
                    <Entry Grid.Column="0"
                           Style="{StaticResource BaseEntry}"
                           Text="{Binding SearchText}"
                           Placeholder="Search passwords..."
                           SemanticProperties.Hint="Search your saved passwords" />

                    <!-- Add button stays as Clicked — needs DisplayPromptAsync dialogs in code-behind -->
                    <Button Grid.Column="1"
                            Style="{StaticResource BaseButton}"
                            Text="Add"
                            Margin="8,0,0,0"
                            Clicked="OnAddPasswordClicked"
                            SemanticProperties.Hint="Add a new password" />

                    <!-- Generate button stays as Clicked — shows result in DisplayAlert -->
                    <Button Grid.Column="2"
                            Style="{StaticResource SecondaryButton}"
                            Text="Generate"
                            Margin="8,0,0,0"
                            Clicked="OnGeneratePasswordClicked"
                            SemanticProperties.Hint="Generate a strong password" />
                </Grid>
            </Frame>
        </StackLayout>

        <!-- Loading indicator: bound to IsLoading on PasswordsViewModel -->
        <ActivityIndicator Grid.Row="1"
                          IsRunning="{Binding IsLoading}"
                          IsVisible="{Binding IsLoading}"
                          Color="#4B24D4"
                          HeightRequest="50"
                          VerticalOptions="Center"
                          HorizontalOptions="Center" />

        <!-- Password list: ItemsSource bound to ObservableCollection<PasswordEntryViewModel> -->
        <!-- Each item's BindingContext is a PasswordEntryViewModel -->
        <CollectionView Grid.Row="1"
                        ItemsSource="{Binding Passwords}"
                        Margin="0,8,0,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Frame Style="{StaticResource PasswordCard}">
                        <Grid RowDefinitions="Auto,Auto,Auto"
                              ColumnDefinitions="*,Auto">

                            <!-- Entry.Service from PasswordEntryViewModel.Entry -->
                            <Label Grid.Row="0" Grid.Column="0"
                                   Text="{Binding Entry.Service}"
                                   Style="{StaticResource HeaderLabel}"
                                   FontSize="{StaticResource FontSizeLarge}" />

                            <StackLayout Grid.Row="1" Grid.Column="0"
                                        Orientation="Horizontal">
                                <Label Text="Username: "
                                       Style="{StaticResource BaseLabel}"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding Entry.Username}"
                                       Style="{StaticResource BaseLabel}" />
                            </StackLayout>

                            <!-- DisplayPassword shows "********" or actual password -->
                            <StackLayout Grid.Row="2" Grid.Column="0"
                                        Orientation="Horizontal">
                                <Label Text="Password: "
                                       Style="{StaticResource BaseLabel}"
                                       FontAttributes="Bold" />
                                <Label Text="{Binding DisplayPassword}"
                                       Style="{StaticResource BaseLabel}" />
                            </StackLayout>

                            <!-- Action buttons bound to PasswordEntryViewModel commands -->
                            <StackLayout Grid.Row="0" Grid.RowSpan="3" Grid.Column="1"
                                       Spacing="8"
                                       VerticalOptions="Center">

                                <!-- ToggleButtonText is "Show" or "Hide" -->
                                <Button Text="{Binding ToggleButtonText}"
                                        Command="{Binding TogglePasswordCommand}"
                                        BackgroundColor="#666666"
                                        TextColor="White"
                                        CornerRadius="8"
                                        FontSize="{StaticResource FontSizeSmall}"
                                        HeightRequest="40"
                                        SemanticProperties.Hint="Show or hide password" />

                                <Button Style="{StaticResource BaseButton}"
                                        Text="Copy"
                                        Command="{Binding CopyCommand}"
                                        FontSize="{StaticResource FontSizeSmall}"
                                        HeightRequest="40"
                                        SemanticProperties.Hint="Copy password to clipboard" />

                                <Button Style="{StaticResource SecondaryButton}"
                                        Text="Edit"
                                        Command="{Binding EditCommand}"
                                        FontSize="{StaticResource FontSizeSmall}"
                                        HeightRequest="40"
                                        SemanticProperties.Hint="Edit this password entry" />

                                <Button Style="{StaticResource DangerButton}"
                                        Text="Delete"
                                        Command="{Binding DeleteCommand}"
                                        FontSize="{StaticResource FontSizeSmall}"
                                        HeightRequest="40"
                                        SemanticProperties.Hint="Delete this password entry" />
                            </StackLayout>
                        </Grid>
                    </Frame>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <StackLayout VerticalOptions="Center"
                           HorizontalOptions="Center">
                    <Label Text="No passwords found"
                           Style="{StaticResource HeaderLabel}"
                           HorizontalOptions="Center" />
                    <Label Text="Add your first password using the + button above"
                           Style="{StaticResource BaseLabel}"
                           HorizontalOptions="Center" />
                </StackLayout>
            </CollectionView.EmptyView>
        </CollectionView>
    </Grid>
</ContentPage>
